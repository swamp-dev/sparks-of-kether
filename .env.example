# Supabase project URL and anonymous public key. Copy this file to
# `.env.local` (which is gitignored) and fill in real values from your
# Supabase project's API settings:
#
#   https://app.supabase.com/project/<project>/settings/api
#
# The anon key is safe to ship to the browser — it's the same key the
# Supabase JS client uses by default. The service role key bypasses RLS
# and MUST stay server-only — its variable name has no `NEXT_PUBLIC_`
# prefix specifically so Next won't bundle it into client code.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc... your-anon-key

# Server-only. Used by the events API route to write the authoritative
# `game_states` snapshot. The table intentionally has no UPDATE RLS
# policy — the snapshot can only move via the engine, applied by the
# server route under service-role auth. If unset, snapshot writes will
# fail at request time.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc... your-service-role-key

# Optional for hosted/dev; REQUIRED for Docker/LAN deploy. The value is
# inlined into the client bundle at build time, so for a LAN deploy
# this must be the host's LAN IP (e.g. http://192.168.1.42:3000), not
# localhost — other devices can't reach a container's loopback. See
# docs/deploy-home-network.md.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
