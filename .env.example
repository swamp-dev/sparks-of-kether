# Supabase project URL and anonymous public key. Copy this file to
# `.env.local` (which is gitignored) and fill in real values from your
# Supabase project's API settings:
#
#   https://app.supabase.com/project/<project>/settings/api
#
# The anon key is safe to ship to the browser — it's the same key the
# Supabase JS client uses by default. The service role key is NOT in
# this file and must never appear in client-side code.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc... your-anon-key

# Optional: site URL passed to next/metadata for canonical / og.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
