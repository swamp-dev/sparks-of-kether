# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Per-PR checklist stamp files written by scripts/checklist-stamp.mjs
# (the PostToolUse:Agent hook OR /finish-ticket's explicit invocation
# of the script). Per-machine, per-branch state used by /ship-ticket
# to verify the per-PR checklist actually ran for the current HEAD.
# Never committed.
.claude/state/
# Claude Code ephemeral runtime files (lock file + dynamically-loaded skills)
.claude/scheduled_tasks.lock
.claude/skills/playtest/

# Node / Next.js
node_modules/
# Anchored variant matches the worktree-symlink form (`node_modules` as
# a symlink, not a directory) created by /start-ticket step 6a. The
# directory pattern above doesn't match a symlink; this rule does.
/node_modules
.next/
out/
dist/
coverage/
.turbo/
*.tsbuildinfo
# next-env.d.ts is committed — see https://nextjs.org/docs/app/building-your-application/configuring/typescript

# Test artifacts
playwright-report/
test-results/
blob-report/
playwright/.cache/
e2e/__screenshots__/

# Mutation testing artifacts (Stryker)
reports/mutation/
.stryker-tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# Misc
.DS_Store

# Supabase Local CLI workspace state
supabase/.branches/
supabase/.temp/

