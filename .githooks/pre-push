#!/usr/bin/env bash
# .githooks/pre-push — runs the fast CI subset (verify + build) on
# every `git push`. The full local CI bundle (incl. e2e and the
# Supabase integration stack) takes too long to gate every push;
# the per-PR checklist in `~/.claude/rules/local-ci-and-admin-merge.md`
# requires a manual `pnpm ci:local` run before merge regardless.
#
# Bypass with `git push --no-verify` (banned in CLAUDE.md). Skip
# explicitly with `SKIP_PRE_PUSH=1 git push` for documented edge
# cases (e.g. pushing a docs-only branch from a worktree without
# node_modules).

set -e

if [[ "${SKIP_PRE_PUSH:-}" == "1" ]]; then
  echo "[pre-push] SKIP_PRE_PUSH=1 — skipping fast-gate checks." >&2
  echo "[pre-push] WARNING: pnpm ci:local (full suite) is still required" >&2
  echo "[pre-push] WARNING: before merge per the per-PR checklist." >&2
  exit 0
fi

# `pnpm` may not be on PATH in some shells; resolve via corepack.
PNPM=${PNPM:-pnpm}

echo "[pre-push] running pnpm ci:local:fast (verify + build)…"
"$PNPM" ci:local:fast
